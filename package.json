{
  "name": "sapana",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "bash scripts/dev.sh",
    "backend:up": "docker compose -f backend/docker-compose.yml up -d",
    "backend:down": "docker compose -f backend/docker-compose.yml down",
    "backend:logs": "docker compose -f backend/docker-compose.yml logs -f",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@9.15.4"
}
